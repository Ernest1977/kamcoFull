# Example .env file for KAMCO FARM

# Django
DJANGO_SECRET_KEY=your-production-secret-key-here
DEBUG=False
ALLOWED_HOSTS=kamcofarm.com,www.kamcofarm.com,127.0.0.1,localhost

# Database
DB_NAME=foss_agro_db
DB_USER=foss_user
DB_PASSWORD=your-db-password-here
DB_HOST=127.0.0.1
DB_PORT=3306

# CORS
CORS_ORIGINS=https://kamcofarm.com,https://www.kamcofarm.com

# URLs
FRONTEND_URL=https://kamcofarm.com
BACKEND_URL=https://kamcofarm.com

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
